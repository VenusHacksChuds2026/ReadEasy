{
  "manifest_version": 3,
  "name": "ReadEasy",
  "short_name": "ReadEasy",
  "description": "Make any website accessible with reading modes, high contrast, dyslexia support, and AI-powered simplification.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ReadEasy - Accessibility Tools",
    "default_icon": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
